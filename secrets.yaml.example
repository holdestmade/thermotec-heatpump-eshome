# Copy this file to `secrets.yaml` and fill in your own values.
# secrets.yaml is read by !secret references in common/esp-config-default.yaml.
# Do NOT commit your real secrets.yaml.

# Your Wi-Fi network
wifi_ssid: "Your WiFi SSID"
wifi_password: "your-wifi-password"

# Password for the fallback access point the device exposes if Wi-Fi fails
ap_password: "fallback-ap-password"

# Home Assistant native API encryption key.
# Generate one with:  openssl rand -base64 32
# (or let the ESPHome dashboard generate it when you add the device)
api_key: "PUT_A_BASE64_32_BYTE_KEY_HERE"

# Password used for over-the-air firmware updates
ota_password: "your-ota-password"
