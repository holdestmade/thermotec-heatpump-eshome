  # ─── Heat Pump Error Code (raw value) ─────────────────────────────────────────
  # Reads register 0x07F2 from the heat pump. 0 = no error, non-zero = fault.
  # The display shows error codes like E03 which appear to map to internal
  # values with an off-by-one offset (E03 = value 4) OR a bitmask (E03 = Bit 2 aka 0x04).
  # I haven't fully decoded the mapping yet, but capturing the raw code here allows
  # for future decoding as more faults are encountered.
  - platform: template
    id: error_code
    name: "Error Code"
    icon: "mdi:alert-circle"
    entity_category: diagnostic
    accuracy_decimals: 0
    # Set from the BLE notify parser, never independently polled
    update_interval: never
    # When the raw code changes, push a translated description and the
    # has-error binary state
    on_value:
      then:
        - component.update: error_description
        - lambda: |-
            // CHANGED (from author): roll up the E-code register AND all the
            // P-code temperature sensor faults into has_error.
            bool err = (id(error_code).state != 0) ||
                       id(inlet_temp_fault).state ||
                       id(outlet_temp_fault).state ||
                       id(ambient_temp_fault).state ||
                       id(coil_temp_fault).state ||
                       id(exhaust_temp_fault).state;
            id(has_error).publish_state(err);




# ─── Text Sensors ───────────────────────────────────────────────────────────
text_sensor:
  # Wall-clock time of the last successful BLE connection. Acts as a heartbeat:
  # if this value stops updating, the device isn't connecting properly.
  # Updated from the ble_client on_connect handler.
  - platform: template
    name: "Last Connected"
    id: last_connected
    icon: "mdi:clock-outline"
    entity_category: diagnostic
    update_interval: never
    lambda: |-
      auto now = id(ha_time).now();
      // Return nothing if time hasn't synced yet — avoids a garbage stamp.
      if (!now.is_valid()) return {};
      char buf[32];
      snprintf(buf, sizeof(buf), "%04d-%02d-%02d %02d:%02d:%02d",
               now.year, now.month, now.day_of_month,
               now.hour, now.minute, now.second);
      return {buf};

  # ─── Current Mode (read from BLE notify) ─────────────────────────────────
  # Reflects the heat pump's actual mode as reported via BLE. Updated by the
  # notify parser when block 0x03E9 arrives — register 0x03F4 at offset 11.
  - platform: template
    id: current_mode
    name: "Current Mode"
    icon: "mdi:thermostat"

  # ─── Heat Pump Error Description ─────────────────────────────────────────────
  # Translates the raw error code into the display code (E0n) and a
  # description. Add new mappings here as you observe other faults.
  #
  # Confirmed mappings (from BLE capture analysis):
  #   value 0 → No error
  #   value 4 → E03: Water Flow (heat pump shows "E03" on its display)
  #
  # Other codes may be added once observed.
  - platform: template
    name: "Error Description"
    id: error_description
    icon: "mdi:alert-circle-outline"
    entity_category: diagnostic
    update_interval: never
    lambda: |-
      // CHANGED (from author): aggregate ALL active faults into one string —
      // E-codes from the error register (now decoded as a bitmask, not a
      // single value) plus the P-code temperature sensor failures.
      std::string result;
      auto append = [&](const std::string &s) {
        if (!result.empty()) result += "; ";
        result += s;
      };

      // E-codes from error register (bitmask at 0x07F2)
      if (id(error_code).has_state()) {
        uint16_t code = (uint16_t)(int)id(error_code).state;
        // Confirmed/inferred mappings on this model:
        if (code & 0x0001) append("E01 High pressure protection");  // bit 0 — inferred
        if (code & 0x0002) append("E02 Low pressure protection");   // bit 1 — confirmed
        if (code & 0x0004) append("E03 No water flow");             // bit 2 — confirmed
        uint16_t known = 0x0007;
        uint16_t unknown = code & ~known;
        if (unknown) {
          char buf[40];
          snprintf(buf, sizeof(buf), "E-unknown bits 0x%04X", unknown);
          append(buf);
        }
      }

      // P-codes from temperature sensor failures
      if (id(inlet_temp_fault).state)   append("P01 Inlet sensor");
      if (id(outlet_temp_fault).state)  append("P02 Outlet sensor");
      if (id(ambient_temp_fault).state) append("P04 Ambient sensor");
      if (id(coil_temp_fault).state)    append("P05 Coil sensor");
      if (id(exhaust_temp_fault).state) append("P81 Exhaust sensor");

      return result.empty() ? std::string("OK") : result;

  # ─── Advanced settings (read-only diagnostics) ────────────────────────────
  # Although it is understood how to set these, it may be dangerous to set them
  # incorrectly so they're implemented as read-only diagnostics for now.
  # Change them using the AquaTemp app and the password "66" for the
  # device parameters menu.
  - platform: template
    id: defrost_type
    name: "Defrost Type"
    icon: "mdi:snowflake-melt"
    entity_category: diagnostic

  - platform: template
    id: heater_mode_type
    name: "Heat Pump Mode Type"
    icon: "mdi:cog"
    entity_category: diagnostic

  - platform: template
    id: pump_mode
    name: "Circulating Pump Mode"
    icon: "mdi:pump"
    entity_category: diagnostic

  # ─── Master Program Version (register 0x07E1) ─────────────────────────────
  # Displayed on the heat pump's control panel as "Master program version
  # number". A DIGI5 value (scaled ×10), so raw 12 = "1.2".
  - platform: template
    name: "Master Program Version"
    id: master_program_version
    icon: "mdi:chip"
    entity_category: diagnostic

  # ─── Main Control Software Code (register 0x07E2) ─────────────────────────
  # Displayed on the heat pump's control panel as "Main control software
  # code". A DIGI1 value (raw integer build code), e.g. 494.
  - platform: template
    name: "Main Control Software Code"
    id: main_control_software_code
    icon: "mdi:chip"
    entity_category: diagnostic

# ─── Climate (ADDED) ──────────────────────────────────
# Thermostat-style HA entity wrapping the Number/Switch/Select above. Modes:
# Off/Heat/Cool/Auto — an exact 1:1 match to the underlying Mode select.
# Target writes are delegated to target_temp_control, which already runs
# write_target_temp; mode and power are delegated to heater_mode and
# heater_power. All BLE writes still flow through the existing scripts.
#
# `compressor_sensor` + `fan_sensor` wire the climate's `action` (Heating /
# Cooling / Fan / Idle) to the pump's actual output bitmask. Without these
# the component would fall back to a temperature-delta guess and report
# HEATING whenever current < target, even with the compressor off — which
# was wrong. With them, action only goes HEATING/COOLING when the compressor
# is genuinely running, and FAN when the fan is on by itself.
climate:
  - platform: pool_heatpump_climate
    name: "Pool Heat Pump"
    id: pool_heat_pump
    sensor: inlet_temp
    target_number: target_temp_control
    power_switch: heater_power
    mode_select: heater_mode
    compressor_sensor: output_compressor
    fan_sensor: output_high_fan

# ─── Scripts ────────────────────────────────────────────────────────────────
script:
  # Send the Modbus "read all status" command to the heat pump.
  # The heat pump replies with 4 fragmented notifications covering blocks
  # 0x03E9, 0x0416, 0x07D1, 0x07FE — the BLE notify parser above picks
  # them apart and publishes to the real sensors.
  - id: poll_heat_pump
    then:
      - ble_client.ble_write:
          id: heatpump_ble
          service_uuid: ${service_uuid}
          characteristic_uuid: ${write_char_uuid}
          value: [0x63, 0x03, 0x00, 0x07, 0x00, 0x2D, 0x3C, 0x54]

  # Write a new target temperature to the register appropriate to the
  # current operating mode:
  #   Heat → 0x0416 (R01 Heating set)
  #   Cool → 0x041B (R06 Cooling set)
  #   Auto → 0x042C (R11 Auto set)
  #
  # If the current mode isn't known yet (e.g. first connect before the heat
  # pump has been polled), default to heat target — that's the most common
  # case and matches the previous behaviour.
  - id: write_target_temp
    parameters:
      temp_x10: int
    then:
      - ble_client.ble_write:
          id: heatpump_ble
          service_uuid: ${service_uuid}
          characteristic_uuid: ${write_char_uuid}
          value: !lambda |-
            // FIXED: in the original config `mode_str` was referenced inside the
            // clamp block BELOW before it was declared — that would not compile.
            // Declared up-front here. (Also: current_mode -> heater_mode.)
            std::string mode_str = id(heater_mode).has_state()
                                   ? id(heater_mode).current_option()
                                   : std::string("Heat");

            // Clamp to the heat pump's accepted range.
            // This is hard-coded, but could read from the diagnostic sensors
            // that output the configured range.
            if (mode_str == "Cool") {
              if (temp_x10 < 100) temp_x10 = 100;   // R09 Min cool = 10°C
              if (temp_x10 > 350) temp_x10 = 350;   // R10 Max cool = 35°C
            } else {
              // Heat & Auto both use heat range
              if (temp_x10 < 150) temp_x10 = 150;   // R04 Min heat = 15°C
              if (temp_x10 > 400) temp_x10 = 400;   // R05 Max heat = 40°C
            }

            // Pick the right register based on current mode
            uint8_t addr_hi = 0x04, addr_lo = 0x16;  // default: heat
            if (mode_str == "Cool") {
              addr_hi = 0x04; addr_lo = 0x1B;
            } else if (mode_str == "Auto") {
              addr_hi = 0x04; addr_lo = 0x2C;
            }

            std::vector<uint8_t> msg = {
              0x63, 0x10, addr_hi, addr_lo, 0x00, 0x01, 0x02,
              (uint8_t)((temp_x10 >> 8) & 0xFF),
              (uint8_t)(temp_x10 & 0xFF)
            };
            uint16_t crc = 0xFFFF;
            for (auto b : msg) {
              crc ^= b;
              for (int j = 0; j < 8; j++)
                crc = (crc & 1) ? ((crc >> 1) ^ 0xA001) : (crc >> 1);
            }
            msg.push_back(crc & 0xFF);
            msg.push_back((crc >> 8) & 0xFF);

            ESP_LOGI("heatpump", "Set %s target = %.1f (reg 0x%02X%02X)",
                     mode_str.c_str(), temp_x10 / 10.0, addr_hi, addr_lo);
            return msg;

  # Write the power on/off state to register 0x03F3.
  # Captured commands:
  #   OFF: 63 10 03 F3 00 01 02 00 00 30 F1
  #   ON:  63 10 03 F3 00 01 02 00 01 F1 31
  - id: write_power_state
    parameters:
      power_on: bool
    then:
      - ble_client.ble_write:
          id: heatpump_ble
          service_uuid: ${service_uuid}
          characteristic_uuid: ${write_char_uuid}
          value: !lambda |-
            uint8_t val = power_on ? 0x01 : 0x00;
            std::vector<uint8_t> msg = {
              0x63, 0x10, 0x03, 0xF3, 0x00, 0x01, 0x02, 0x00, val
            };
            // CRC16 (Modbus RTU)
            uint16_t crc = 0xFFFF;
            for (auto b : msg) {
              crc ^= b;
              for (int j = 0; j < 8; j++)
                crc = (crc & 1) ? ((crc >> 1) ^ 0xA001) : (crc >> 1);
            }
            msg.push_back(crc & 0xFF);
            msg.push_back((crc >> 8) & 0xFF);
            ESP_LOGI("heatpump", "Set power = %s", power_on ? "ON" : "OFF");
            return msg;

  # Write the operating mode to register 0x03F4 (and 0x03F5).
  # The app writes 2 consecutive registers — we replicate that exactly to
  # match observed behaviour. Register 0x03F5's purpose isn't fully
  # understood but appears mode-dependent.
  #
  # Captured commands (CRCs verified):
  #   HEAT: 63 10 03 F4 00 02 04 00 00 00 00 1C 51
  #   COOL: 63 10 03 F4 00 02 04 00 01 00 88 4D F7
  #   AUTO: 63 10 03 F4 00 02 04 00 02 00 8C BC 34
  - id: write_mode
    parameters:
      mode: string
    then:
      - ble_client.ble_write:
          id: heatpump_ble
          service_uuid: ${service_uuid}
          characteristic_uuid: ${write_char_uuid}
          value: !lambda |-
            // Translate string mode to (mode_val, second_reg) pair.
            // The second register's exact meaning is unknown but the values
            // below match what the official AquaTemp app sends.
            uint8_t mode_lo, sec_hi, sec_lo;
            if (mode == "Cool") {
              mode_lo = 0x01; sec_hi = 0x00; sec_lo = 0x88;
            } else if (mode == "Auto") {
              mode_lo = 0x02; sec_hi = 0x00; sec_lo = 0x8C;
            } else {
              // Default to Heat (mode 0) — also covers any unrecognised string
              mode_lo = 0x00; sec_hi = 0x00; sec_lo = 0x00;
            }

            std::vector<uint8_t> msg = {
              0x63, 0x10, 0x03, 0xF4, 0x00, 0x02, 0x04,
              0x00, mode_lo,
              sec_hi, sec_lo
            };
            // CRC16 (Modbus RTU)
            uint16_t crc = 0xFFFF;
            for (auto b : msg) {
              crc ^= b;
              for (int j = 0; j < 8; j++)
                crc = (crc & 1) ? ((crc >> 1) ^ 0xA001) : (crc >> 1);
            }
            msg.push_back(crc & 0xFF);
            msg.push_back((crc >> 8) & 0xFF);
            ESP_LOGI("heatpump", "Set mode = %s", mode.c_str());
            return msg;

# ─── Periodic Polling ───────────────────────────────────────────────────────
# CHANGED: previously only effective while "awake" (deep-sleep prevented). The
# device is now always powered, so this fires every 30s continuously to keep
# all sensors and the Number/Switch/Select controls in sync with the pump.
interval:
  - interval: 30s
    then:
      - script.execute: poll_heat_pump
