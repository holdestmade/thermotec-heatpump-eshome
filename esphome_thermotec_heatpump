esphome:
  name: heat-pump-controller
  friendly_name: Heat Pump Controller
  comment: ESP32
  areas:
    - id: back_garden_area
      name: "Back Garden"

esp32:
  board: esp32-c3-devkitm-1
  framework:
    type: esp-idf

packages:
  device_base: !include common/esp-config-default.yaml

external_components:
  - source:
      type: local
      path: components
    components: [pool_heatpump_climate]

# ─── WHAT CHANGED IN THIS VERSION (vs the original deep-sleep / HA-helper config) ──
#  * REMOVED: deep_sleep component + the whole on_boot wake/sleep state machine.
#             The device is now mains/USB powered and stays awake permanently.
#  * REMOVED: the four Home Assistant helper "mirror" entities (desired_*,
#             prevent_deep_sleep). You no longer need to create ANY input_*
#             helpers in HA. Control now lives natively on the ESP:
#               - number  "Target Temperature"  (was input_number mirror)
#               - switch  "Power"               (was input_boolean mirror)
#               - select  "Mode"                (was input_select mirror)
#             These are created automatically in HA by the API and act as BOTH
#             the control and the live status readout (the BLE notify parser
#             publishes the heat pump's real values back into them).
#  * REMOVED: battery_voltage + battery_level sensors. They read the Firebeetle's
#             on-board LiPo divider, which is meaningless when mains powered.
#             (If you still run off a cell, ask and I'll drop them back in.)
#  * REMOVED: the "reconcile HA helpers" sync block in ble_client on_connect.
#             With the device always awake, every control change is written to
#             the pump immediately by its own action, so there's nothing to
#             reconcile on connect — we just read the pump and reflect it.
#  * FIXED  (pre-existing bug): write_target_temp used `mode_str` before it was
#             declared — that would NOT compile. Declaration moved up-front.
#  * ADDED  (pre-existing gap): the notify parser published to heating_set_temp,
#             cooling_set_temp, auto_set_temp, min/max_heat/cool_temp — but those
#             sensors were never defined, so the original would not compile.
#             Their definitions are added under the sensor: section.

# ─── Globals ────────────────────────────────────────────────────────────────
substitutions:
  service_uuid: "0000ff01-0000-1000-8000-00805f9b34fb"
  write_char_uuid: "0000ff03-0000-1000-8000-00805f9b34fb"
  notify_char_uuid: "0000ff02-0000-1000-8000-00805f9b34fb"
  # REMOVED: the four `home_assistant_*` helper-name substitutions.
  # Control is now native to ESPHome (see number:/switch:/select: below),
  # so there are no HA helpers to point at any more.

# ─── Globals ────────────────────────────────────────────────────────────────
globals:
  # Tracks whether the BLE link to the heat pump is up.
  # CHANGED: no longer used for sleep gating (deep sleep is gone). It is still
  # used by the ble_status binary sensor and is handy for conditional logic.
  # NOT restored — BLE state from a previous boot is meaningless.
  - id: ble_connected
    type: bool
    initial_value: 'false'
    restore_value: no

# ─── Logging ────────────────────────────────────────────────────────────────
logger:
  level: INFO
  baud_rate: 115200
  logs:
    # Silence the noisy "Error reading char at handle 16, status=2" warning
    # that fires once at boot — ble_client tries to read the notify
    # characteristic at startup and the heat pump rejects it (notify-only).
    ble_sensor: ERROR
    # Quieten per-publish state changes on routine sensor updates.
    sensor: WARN

# ─── Time ───────────────────────────────────────────────────────────────────
# Sync from HA over the API. Required for the last_connected text sensor
# to display a human-readable timestamp.
time:
  - platform: homeassistant
    id: ha_time

# REMOVED: the deep_sleep: component. The device no longer sleeps.

# ─── BLE ────────────────────────────────────────────────────────────────────
# NOTE: now that the device is always awake you could relax this scan duty
# cycle (e.g. interval: 320ms / window: 30ms) to lower CPU/RF load — the
# aggressive window==interval was only there to win the connection race during
# the brief deep-sleep wake window. Left aggressive here; it's harmless because
# auto_connect stops scanning once connected.
esp32_ble_tracker:
  scan_parameters:
    interval: 320ms
    window: 30ms
    active: true

ble_client:
  - mac_address: "08:06:BC:80:C0:13"
    id: heatpump_ble
    auto_connect: true
    on_connect:
      then:
        - logger.log: "Heat pump connected"
        - lambda: 'id(ble_connected) = true;'
        # Wait briefly for service discovery to complete, then poll.
        - delay: 3s
        # Poll the heat pump. The notify parser populates every sensor AND
        # reflects the pump's live power/mode/target back into the native
        # Number/Switch/Select controls so HA shows the true current state.
        - script.execute: poll_heat_pump
        # CHANGED: removed the old "Reconcile HA helpers" block (target/mode/
        # power sync). It only mattered when a helper could change while the
        # device was asleep. The device is always awake now, so every control
        # change is written to the pump immediately by its own action.
        - component.update: last_connected
    on_disconnect:
      then:
        - logger.log: "Heat pump disconnected"
        - lambda: 'id(ble_connected) = false;'

# ─── Native Controls (ADDED — replace the old HA helper mirrors) ─────────────
# These three entities are created automatically in Home Assistant via the API.
# Each is BOTH the control (writing to the pump on change) and the live status
# readout (the BLE notify parser publishes the pump's real value back into it).
# `optimistic: true` gives instant UI feedback; the next poll confirms/corrects.
number:
  - platform: template
    name: "Target Temperature"
    id: target_temp_control
    # Range covers both heat (15–40) and cool (10–35); write_target_temp
    # clamps to the correct per-mode range before sending.
    min_value: 10
    max_value: 40
    step: 0.5
    unit_of_measurement: "°C"
    device_class: temperature
    mode: slider
    optimistic: true
    set_action:
      - logger.log:
          level: INFO
          format: "Target set to %.1f — writing to heat pump"
          args: ['x']
      - script.execute:
          id: write_target_temp
          temp_x10: !lambda 'return (int)(x * 10);'
      - delay: 2s
      # Re-poll to confirm the write took effect
      - script.execute: poll_heat_pump

switch:
  - platform: template
    name: "Power"
    id: heater_power
    icon: "mdi:power"
    optimistic: true
    turn_on_action:
      - logger.log: "Power switch ON — writing to heat pump"
      - script.execute:
          id: write_power_state
          power_on: true
      - delay: 2s
      - script.execute: poll_heat_pump
    turn_off_action:
      - logger.log: "Power switch OFF — writing to heat pump"
      - script.execute:
          id: write_power_state
          power_on: false
      - delay: 2s
      - script.execute: poll_heat_pump

select:
  - platform: template
    name: "Mode"
    id: heater_mode
    icon: "mdi:thermostat"
    optimistic: true
    options:
      - "Heat"
      - "Cool"
      - "Auto"
    set_action:
      - logger.log:
          level: INFO
          format: "Mode set to %s — writing to heat pump"
          args: ['x.c_str()']
      - script.execute:
          id: write_mode
          mode: !lambda 'return x;'
      - delay: 2s
      # Re-poll so the target temperature display follows the new mode.
      - script.execute: poll_heat_pump




# ─── Binary Sensors ─────────────────────────────────────────────────────────
binary_sensor:
  # REMOVED: prevent_deep_sleep_switch  (no sleep to prevent).
  # REMOVED: desired_power_state        (replaced by the native `switch` above).
  # REMOVED: current_power_state        (folded into the native `switch` —
  #          the notify parser now publishes the pump's power state into it).

  # ── BLE link status ───────────────────────────────────────────────────────
  - platform: template
    id: ble_status
    name: "Heat Pump BLE Connection"
    device_class: connectivity
    lambda: 'return id(ble_connected);'

  # ─── Diagnostic outputs ───────────────────────────────────────────────────
  # output_compressor, output_circulate_pump, output_high_fan and output_4way_valve are
  # decoded from the bitmask at register 0x07E3 in the notify response.
  - platform: template
    id: output_compressor
    name: "Compressor"
    icon: "mdi:engine"
    device_class: running
    entity_category: diagnostic
    filters:
      - delayed_on_off: 1s    # debounce: only publish if state holds for 1 second to remove the duplicate BLE responses

  - platform: template
    id: output_circulate_pump
    name: "Circulate Pump"
    icon: "mdi:pump"
    device_class: running
    entity_category: diagnostic
    filters:
      - delayed_on_off: 1s    # debounce: only publish if state holds for 1 second to remove the duplicate BLE responses

  - platform: template
    id: output_high_fan
    name: "High Fan"
    icon: "mdi:fan"
    device_class: running
    entity_category: diagnostic
    filters:
      - delayed_on_off: 1s    # debounce: only publish if state holds for 1 second to remove the duplicate BLE responses

  - platform: template
    id: output_4way_valve
    name: "4-Way Valve"
    icon: "mdi:valve"
    device_class: opening
    entity_category: diagnostic
    filters:
      - delayed_on_off: 1s    # debounce: only publish if state holds for 1 second to remove the duplicate BLE responses

  - platform: template
    id: has_error
    name: "Has Error"
    icon: "mdi:alert"
    device_class: problem
    entity_category: diagnostic

  # ─── Temperature sensor fault indicators (P-codes) ─────────────────────────
  # NEW (from author): raised when a temperature register reads the pump's
  # "sensor failure" sentinel value (see the pub_temp lambda in the parser).
  # Each on_state recomputes the has_error rollup so it reflects both the
  # E-code register and any sensor fault.
  #   P01=Inlet (T02), P02=Outlet (T03), P04=Ambient (T05),
  #   P05=Coil (T04),  P81=Exhaust (T06)
  - platform: template
    id: inlet_temp_fault
    name: "Inlet Temp Sensor Fault (P01)"
    device_class: problem
    entity_category: diagnostic
    on_state:
      then:
        - component.update: error_description
        - lambda: |-
            bool err = (id(error_code).has_state() && id(error_code).state != 0) ||
                       id(inlet_temp_fault).state ||
                       id(outlet_temp_fault).state ||
                       id(ambient_temp_fault).state ||
                       id(coil_temp_fault).state ||
                       id(exhaust_temp_fault).state;
            id(has_error).publish_state(err);

  - platform: template
    id: outlet_temp_fault
    name: "Outlet Temp Sensor Fault (P02)"
    device_class: problem
    entity_category: diagnostic
    on_state:
      then:
        - component.update: error_description
        - lambda: |-
            bool err = (id(error_code).has_state() && id(error_code).state != 0) ||
                       id(inlet_temp_fault).state ||
                       id(outlet_temp_fault).state ||
                       id(ambient_temp_fault).state ||
                       id(coil_temp_fault).state ||
                       id(exhaust_temp_fault).state;
            id(has_error).publish_state(err);

  - platform: template
    id: ambient_temp_fault
    name: "Ambient Temp Sensor Fault (P04)"
    device_class: problem
    entity_category: diagnostic
    on_state:
      then:
        - component.update: error_description
        - lambda: |-
            bool err = (id(error_code).has_state() && id(error_code).state != 0) ||
                       id(inlet_temp_fault).state ||
                       id(outlet_temp_fault).state ||
                       id(ambient_temp_fault).state ||
                       id(coil_temp_fault).state ||
                       id(exhaust_temp_fault).state;
            id(has_error).publish_state(err);

  - platform: template
    id: coil_temp_fault
    name: "Coil Temp Sensor Fault (P05)"
    device_class: problem
    entity_category: diagnostic
    on_state:
      then:
        - component.update: error_description
        - lambda: |-
            bool err = (id(error_code).has_state() && id(error_code).state != 0) ||
                       id(inlet_temp_fault).state ||
                       id(outlet_temp_fault).state ||
                       id(ambient_temp_fault).state ||
                       id(coil_temp_fault).state ||
                       id(exhaust_temp_fault).state;
            id(has_error).publish_state(err);

  - platform: template
    id: exhaust_temp_fault
    name: "Exhaust Temp Sensor Fault (P81)"
    device_class: problem
    entity_category: diagnostic
    on_state:
      then:
        - component.update: error_description
        - lambda: |-
            bool err = (id(error_code).has_state() && id(error_code).state != 0) ||
                       id(inlet_temp_fault).state ||
                       id(outlet_temp_fault).state ||
                       id(ambient_temp_fault).state ||
                       id(coil_temp_fault).state ||
                       id(exhaust_temp_fault).state;
            id(has_error).publish_state(err);

  # ─── Unit Running State ───────────────────────────────────────────────────
  # NEW (from author): the heat pump's internal "I'm running" state
  # (register 0x07DB). Differs from the Power switch:
  #   - Power switch = the user's on/off command
  #   - unit_running = actually operating (reads 0 even when powered on if the
  #                    pump has safety-stopped due to a fault).
  - platform: template
    id: unit_running
    name: "Unit Running"
    icon: "mdi:engine"
    device_class: running
    entity_category: diagnostic

# ─── Sensors ────────────────────────────────────────────────────────────────
sensor:
  # REMOVED: desired_target_temp  (replaced by the native `number` above).
  # REMOVED: current_target_temp  (folded into the native `number` — the notify
  #          parser publishes the pump's reported target into target_temp_control).
  # REMOVED: battery_voltage + battery_level (meaningless on mains/USB power).

  # ── BLE Notification Parser (internal) ────────────────────────────────────
  # This sensor subscribes to BLE notifications from the heat pump and parses
  # each Modbus reply into the real sensors below. It has no value of its
  # own — returning {} from the lambda means "don't publish".
  #
  # Each notification arrives as a std::vector<uint8_t> in `x`.
  - platform: ble_client
    type: characteristic
    ble_client_id: heatpump_ble
    id: notify_handler
    name: "Heat Pump Raw Notify"
    service_uuid: ${service_uuid}
    characteristic_uuid: ${notify_char_uuid}
    notify: true
    internal: true
    lambda: |-
      // Sanity check
      if (x.size() < 5 || x[0] != 0x63) return {};

      // Write ACK (8-byte Modbus 0x10 response)
      if (x[1] == 0x10 && x.size() == 8) {
        uint16_t ack = (x[2] << 8) | x[3];
        ESP_LOGI("heatpump", "Write ACK for 0x%04X", ack);
        return {};
      }

      // Modbus exception
      if ((x[1] & 0x80) && x.size() >= 5) {
        ESP_LOGW("heatpump", "Modbus exception 0x%02X for func 0x%02X",
                 x[2], x[1] & 0x7F);
        return {};
      }

      // Data block (fragmented read response).
      // Format: 63 10 [block_hi] [block_lo] 00 2D 5A [9 regs of data...]
      if (x[1] != 0x10 || x.size() < 9) return {};

      uint16_t block = (x[2] << 8) | x[3];
      auto rd = [&](size_t i) -> int16_t {
        size_t p = 7 + i * 2;
        if (p + 1 >= x.size()) return 0;
        return (int16_t)((x[p] << 8) | x[p+1]);
      };

      if (block == 0x07FE) {
        // NEW (from author): per-sensor failure detection. The heat pump
        // signals different failure sentinel values per sensor:
        //   T02 Inlet, T03 Outlet, T04 Coil, T06 Exhaust → 0x7FFD
        //   T05 Ambient                                  → 0xFFF6 (-1.0°C)
        // T01 Suction always reads 0x7FFD on single-system models.
        // When a sensor is faulted we publish NAN to the temperature (so HA
        // shows "unavailable" rather than a bogus reading) and raise the
        // matching P-code fault binary sensor.
        auto pub_temp = [](esphome::template_::TemplateSensor *temp_sensor,
                           esphome::template_::TemplateBinarySensor *fault_sensor,
                           int16_t raw,
                           bool is_ambient) {
          bool fault;
          if (is_ambient) {
            fault = (raw == (int16_t)0xFFF6) || ((raw & 0xFFF0) == 0x7FF0);
          } else {
            fault = ((raw & 0xFFF0) == 0x7FF0);
          }
          fault_sensor->publish_state(fault);
          if (fault) {
            temp_sensor->publish_state(NAN);
          } else {
            temp_sensor->publish_state(raw / 10.0);
          }
        };

        pub_temp(id(inlet_temp),   id(inlet_temp_fault),   rd(1), false);
        pub_temp(id(outlet_temp),  id(outlet_temp_fault),  rd(2), false);
        pub_temp(id(coil_temp),    id(coil_temp_fault),    rd(3), false);
        pub_temp(id(ambient_temp), id(ambient_temp_fault), rd(4), true);
        pub_temp(id(exhaust_temp), id(exhaust_temp_fault), rd(5), false);
        ESP_LOGI("heatpump", "Temps updated");
      } else if (block == 0x0416) {
        // Each mode has its own target register in this block:
        //   reg 0  (0x0416) = R01 Heating set
        //   reg 5  (0x041B) = R06 Cooling set
        //   reg 22 (0x042C) = R11 Auto set
        // The heat pump's display shows whichever matches the current mode,
        // so we mirror that here.
        // CHANGED: current_mode -> heater_mode (the native Select).
        std::string mode_str = id(heater_mode).has_state()
                               ? id(heater_mode).current_option()
                               : std::string("Heat");
        float displayed_target;
        if (mode_str == "Cool")      displayed_target = rd(5)  / 10.0;
        else if (mode_str == "Auto") displayed_target = rd(22) / 10.0;
        else                         displayed_target = rd(0)  / 10.0;
        // CHANGED: publish into the native Number control (was current_target_temp).
        // Guarded by a 0.05°C delta to suppress duplicate BLE responses.
        if (!id(target_temp_control).has_state() ||
            fabsf(id(target_temp_control).state - displayed_target) > 0.05f) {
          id(target_temp_control).publish_state(displayed_target);
        }
        ESP_LOGI("heatpump", "Target (%s mode) = %.1f",
                 mode_str.c_str(), displayed_target);

        // Diagnostic sensors — always publish all three set-points
        id(heating_set_temp).publish_state(rd(0) / 10.0);
        id(cooling_set_temp).publish_state(rd(5) / 10.0);
        id(auto_set_temp).publish_state(rd(22) / 10.0);
        id(min_heat_temp).publish_state(rd(3) / 10.0);
        id(max_heat_temp).publish_state(rd(4) / 10.0);
        id(min_cool_temp).publish_state(rd(8) / 10.0);
        id(max_cool_temp).publish_state(rd(9) / 10.0);

        // D06 Defrost type at reg 15 (0x0425): 0=Normal, 1=Eco
        int16_t dt = rd(15);
        id(defrost_type).publish_state(
          dt == 0 ? std::string("Normal") :
          dt == 1 ? std::string("Eco") :
          std::string("Unknown"));

        ESP_LOGI("heatpump", "Heat Pump target = %.1f", rd(0) / 10.0);
      } else if (block == 0x03E9) {
        // Block containing register 0x03F3 at offset 10 = power state
        int16_t power = rd(10);
        bool is_on = (power != 0);
        // CHANGED: publish into the native Switch control (was current_power_state).
        if (id(heater_power).state != is_on) {
          id(heater_power).publish_state(is_on);
        }

        // Mode at offset 11 (register 0x03F4)
        // 0 = Heat, 1 = Cool, 2 = Auto
        int16_t mode = rd(11);
        const char *mode_str;
        switch (mode) {
          case 0:  mode_str = "Heat"; break;
          case 1:  mode_str = "Cool"; break;
          case 2:  mode_str = "Auto"; break;
          default: mode_str = "Unknown"; break;
        }
        // CHANGED: publish into the native Select control (was current_mode).
        // Skip "Unknown" so we never push an option the Select doesn't list.
        std::string ms(mode_str);
        if (ms != "Unknown" &&
            (!id(heater_mode).has_state() || id(heater_mode).current_option() != ms)) {
          id(heater_mode).publish_state(ms);
        }

        // H06 Mode type at reg 22 (0x03FF): 1=Heat pump, 2=Heat only (4-way valve)
        int16_t mt = rd(22);
        id(heater_mode_type).publish_state(
          mt == 1 ? std::string("Heat pump") :
          mt == 2 ? std::string("Heat only (4-way valve)") :
          std::string("Unknown"));

        // P01 Circulating pump mode at reg 36 (0x040D): 0=Normal, 1=Stop, 2=Interval
        int16_t pm = rd(36);
        id(pump_mode).publish_state(
          pm == 0 ? std::string("Normal") :
          pm == 1 ? std::string("Stop") :
          pm == 2 ? std::string("Interval") :
          std::string("Unknown"));

        ESP_LOGI("heatpump", "Heat Pump power=%s mode=%s", is_on ? "ON" : "OFF", mode_str);

      } else if (block == 0x07D1) {
        // Block containing output states at offset 18 (register 0x07E3).
        // Bitmask:
        //   bit 0 (0x01) = compressor  (confirmed via capture)
        //   bit 1 (0x02) = circulate pump  (inferred from app O01-O04 order)
        //   bit 2 (0x04) = high fan  (confirmed via capture)
        //   bit 3 (0x08) = 4-way valve  (inferred from app O01-O04 order)
        int16_t outputs = rd(18);
        id(output_compressor).publish_state((outputs & 0x01) != 0);
        id(output_circulate_pump).publish_state((outputs & 0x02) != 0);
        id(output_high_fan).publish_state((outputs & 0x04) != 0);
        id(output_4way_valve).publish_state((outputs & 0x08) != 0);

        // Firmware identity (block 0x07D1 reg 16 + reg 17).
        // These are stable across reads — published once per session.
        // reg 16 (0x07E1) = "Master program version number", DIGI5 (×10)
        //                   e.g. raw 12 → "1.2"
        // reg 17 (0x07E2) = "Main control software code", DIGI1 (raw)
        //                   e.g. 494
        uint16_t master_ver_raw = rd(16);
        uint16_t soft_code      = rd(17);

        char ver_buf[16];
        snprintf(ver_buf, sizeof(ver_buf), "%u.%u",
                 master_ver_raw / 10, master_ver_raw % 10);
        std::string ver_str(ver_buf);
        if (!id(master_program_version).has_state() ||
            id(master_program_version).state != ver_str) {
          id(master_program_version).publish_state(ver_str);
        }

        char code_buf[16];
        snprintf(code_buf, sizeof(code_buf), "%u", soft_code);
        std::string code_str(code_buf);
        if (!id(main_control_software_code).has_state() ||
            id(main_control_software_code).state != code_str) {
          id(main_control_software_code).publish_state(code_str);
        }

        // NEW (from author): unit running state at offset 10 (register 0x07DB).
        // 0 = stopped (may indicate self-shutdown after a fault), 1 = running.
        // Distinct from power state (0x03F3): power = user's on/off command,
        // unit_running = whether the pump is actually operating.
        id(unit_running).publish_state(rd(10) != 0);

        // Error code at offset 33 (register 0x07F2).
        // 0 = no error; 4 = E03 (water flow) confirmed via BLE capture, but see comment below on
        // error_code and error_description sensor for more details on the raw code and display mapping.
        int16_t err = rd(33);
        id(error_code).publish_state(err);

        ESP_LOGI("heatpump", "Outputs = 0x%04X, Error = 0x%04X", outputs, err);
      }
      return {};

  # ── Temperature sensors (parsed from BLE notifications) ───────────────────
  - platform: template
    id: inlet_temp
    name: "Inlet Water Temperature"
    unit_of_measurement: "°C"
    device_class: temperature
    state_class: measurement
    accuracy_decimals: 1
    filters:
      - delta: 0.05   # only publish if value moved more than 0.05°C to remove the duplicate BLE responses

  - platform: template
    id: outlet_temp
    name: "Outlet Water Temperature"
    unit_of_measurement: "°C"
    device_class: temperature
    state_class: measurement
    accuracy_decimals: 1
    filters:
      - delta: 0.05   # only publish if value moved more than 0.05°C to remove the duplicate BLE responses

  - platform: template
    id: coil_temp
    name: "Coil Temperature"
    unit_of_measurement: "°C"
    device_class: temperature
    state_class: measurement
    accuracy_decimals: 1
    filters:
      - delta: 0.05   # only publish if value moved more than 0.05°C to remove the duplicate BLE responses

  - platform: template
    id: ambient_temp
    name: "Ambient Temperature"
    unit_of_measurement: "°C"
